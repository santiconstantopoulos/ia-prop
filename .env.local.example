# Supabase — copiá este archivo a .env.local y completá con tus credenciales.
# .env.local está gitignoreado: nunca se commitea.

# URL del proyecto (pública, puede ir con prefijo NEXT_PUBLIC_)
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co

# Secret key (service-role). SOLO server-side. Nunca la expongas al cliente
# ni le pongas prefijo NEXT_PUBLIC_.
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx
